/*Вам нужно написать демона, который раз в минуту пишет лог в файл app.log.
Практическая задача: Предложите механизм (с использованием системных вызовов из вашей теории), 
который гарантирует, что при внезапном падении процесса все уже записанные данные действительно оказались на диске, 
а не "зависли" в буферах ОС. В какой момент и какой вызов вы добавите?*/

#include <stdio.h>
#include <unistd.h>
#include <time.h>

void write_log(const char *msg) {
    FILE *f = fopen("app.log", "a");
    if (!f) return;

    // отключаем буферизацию stdio, чтобы fflush был эффективным
    setbuf(f, NULL);

    // записываем данные в буфер пользователя
    fprintf(f, "[%ld] %s\n", time(NULL), msg);

    // сбрасываем из пользовательского буфера в ядро
    fflush(f);

    // используем fdatasync, т.к. метаданные (размер, дата) не критичны для целостности лога
    fdatasync(fileno(f));

    fclose(f);
}
